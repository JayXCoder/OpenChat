APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=OllamaChat Backend
CORS_ORIGINS=http://localhost:42817
DATABASE_URL=postgresql+asyncpg://ollamachat:change_me@postgres:5432/ollamachat
# Compose overrides this. Typical: host Ollama → host.docker.internal:11434; Ollama container → http://ollama:11434.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen3:latest
OLLAMA_MODELS=qwen3.5:27b,gpt-oss:20b,nomic-embed-text:v1.5,glm-5:cloud,gpt-oss:120b-cloud,kimi-k2.5:cloud,qwen3-coder:30b,qwen3:30b,kimi-k2-thinking:cloud,qwen3-vl:8b,qwen3:8b,qwen3:latest
OPENAI_COMPAT_MODELS=gpt-4o-mini,gpt-4.1-mini
REQUEST_TIMEOUT_SECONDS=120
