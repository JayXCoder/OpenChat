# Merge order: base + host Ollama overlay (backend host network, Ollama at 127.0.0.1:11434).
# For bridge-only: COMPOSE_FILE=docker-compose.yml:docker-compose.bridge.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.host-ollama.yml
COMPOSE_PROJECT_NAME=ollamachat
FRONTEND_PORT=42817
BACKEND_PORT=37891
POSTGRES_PORT=28147
POSTGRES_DB=ollamachat
POSTGRES_USER=ollamachat
POSTGRES_PASSWORD=change_me
OLLAMA_PORT=51793
# Required for docker-compose.host-ollama.yml — DB URL for backend (host network → Postgres on localhost).
# Password must be URL-encoded (e.g. @ → %40).
BACKEND_DATABASE_URL=postgresql+asyncpg://ollamachat:change_me@127.0.0.1:28147/ollamachat
# docker-compose.bridge.yml: Ollama on host (not the ollama container). Use http://ollama:11434 with --profile ollama.
OLLAMA_HOST_URL=http://host.docker.internal:11434
